{
  "manifest_version": 3,
  "name": "VOrganise",
  "version": "2.0.0",
  "description": "Smart VTOP course material downloader — filter by faculty, module, and download into organised folders.",
  "permissions": [
    "downloads",
    "activeTab",
    "scripting",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://vtop.vit.ac.in/*",
    "https://vtop2.vit.ac.in/*",
    "https://*.vit.ac.in/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://vtop.vit.ac.in/*",
        "https://vtop2.vit.ac.in/*",
        "https://*.vit.ac.in/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
